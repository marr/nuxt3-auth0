NUXT_AUTH_SESSION_PASSWORD=<32 char string>

# Auth0
NUXT_AUTH0_REDIRECT_URI=http://localhost:3000/api/callback
NUXT_AUTH0_AUDIENCE=https://<your auth0 tenant>.auth0.com/api/v2/
NUXT_AUTH0_BASE_URL=<your auth0 tenant>
NUXT_AUTH0_CLIENT_ID=<your auth0 client id>
NUXT_AUTH0_CLIENT_SECRET=<your auth0 client secret> *optional* only needed for use of management api